# SaaS Marketing Engine — backend settings (copy to `backend/.env` and fill in secrets).
# All vars are SME_-prefixed and loaded by app/config.py. `.env` is gitignored; this template
# is committed. Anything left commented falls back to the default shown.

# --- Secrets (set these; leaving them unset makes the dependent feature fail loudly) ---

# Anthropic API key for strategy/crank LLM calls (S1.1+).
SME_ANTHROPIC_API_KEY=

# Fernet key for the credentials vault (S0.4) — never stored in the DB.
# Generate: python -c "from app.secrets.vault import generate_key; print(generate_key())"
SME_VAULT_KEY=

# --- Optional (defaults shown) ---

# SME_APP_NAME=SaaS Marketing Engine
# SME_ENVIRONMENT=dev

# SQLite (WAL) in v1; a Postgres URL in Phase B.
# SME_DATABASE_URL=sqlite:///./sme.db

# Per-product isolated workspace (generated site/content + vault).
# SME_WORKSPACE_ROOT=./workspace

# Landing sites (S2.1): public funnel-API origin baked into each generated site's JS, and the
# nginx web root that built sites + their vhosts deploy under (keyed by marketing_domain).
# SME_PUBLIC_API_BASE_URL=http://localhost:8010
# SME_NGINX_SITES_ROOT=./deploy/sites

# Browser origin(s) allowed to call the private API (comma-separated).
# SME_CORS_ORIGINS=http://localhost:3010

# In-process worker loop / scheduler intervals (seconds).
# SME_WORKER_INTERVAL_SECONDS=5
# SME_HEARTBEAT_INTERVAL_SECONDS=60

# v1 ports (verified free on the dev VPS — see infra/deploy/PORTS.md).
# SME_API_PORT=8010
# SME_DASHBOARD_PORT=3010
