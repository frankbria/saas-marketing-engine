# SaaS Marketing Engine — backend settings (copy to `backend/.env` and fill in secrets).
# All vars are SME_-prefixed and loaded by app/config.py. `.env` is gitignored; this template
# is committed. Anything left commented falls back to the default shown.

# --- Secrets (set these; leaving them unset makes the dependent feature fail loudly) ---

# Anthropic API key for strategy/crank LLM calls (S1.1+).
SME_ANTHROPIC_API_KEY=

# Fernet key for the credentials vault (S0.4) — never stored in the DB.
# Generate: python -c "from app.secrets.vault import generate_key; print(generate_key())"
SME_VAULT_KEY=

# Stripe secret API key (`sk_test_…` in dev) — creates the product/price + Checkout sessions (S2.3).
SME_STRIPE_API_KEY=

# Stripe webhook signing secret (`whsec_…`) — verifies the funnel webhook (S2.2/S2.5).
SME_STRIPE_WEBHOOK_SECRET=

# GPU provider API key (S5.0, RunPod) — provisions the ephemeral media worker pod. Never stored
# in the DB (§9); unset, media provisioning fails loudly (text/blog crank is unaffected).
SME_GPU_API_KEY=

# --- Optional (defaults shown) ---

# SME_APP_NAME=SaaS Marketing Engine
# SME_ENVIRONMENT=dev

# SQLite (WAL) in v1; a Postgres URL in Phase B.
# SME_DATABASE_URL=sqlite:///./sme.db

# Per-product isolated workspace (generated site/content + vault).
# SME_WORKSPACE_ROOT=./workspace

# Landing sites (S2.1): public funnel-API origin baked into each generated site's JS, and the
# nginx web root that built sites + their vhosts deploy under (keyed by marketing_domain).
# SME_PUBLIC_API_BASE_URL=http://localhost:8010
# SME_NGINX_SITES_ROOT=./deploy/sites

# Browser origin(s) allowed to call the private API (comma-separated).
# SME_CORS_ORIGINS=http://localhost:3010

# Per-provider OAuth redirect flow (S4.8.2). `oauth_redirect_base_url` is the backend origin the
# provider redirects back to (the callback path is appended for the `redirect_uri`); it MUST be
# https off localhost (validated at startup) so OAuth code/state never cross the wire in plaintext.
# `dashboard_base_url` is where the callback bounces the operator's browser once tokens are stored.
# SME_OAUTH_REDIRECT_BASE_URL=http://localhost:8010
# SME_DASHBOARD_BASE_URL=http://localhost:3010

# In-process worker loop / scheduler intervals (seconds).
# SME_WORKER_INTERVAL_SECONDS=5
# SME_HEARTBEAT_INTERVAL_SECONDS=60

# S4.4 deterministic guard: comma-separated case-insensitive regex patterns that hard-block content
# (extends the curated default of guarantee/compliance red-flags; a bad regex fails at startup).
# SME_GUARD_BLOCKLIST=guarantee(d|s)?,risk[\s-]?free,miracle

# v1 ports (verified free on the dev VPS — see infra/deploy/PORTS.md).
# SME_API_PORT=8010
# SME_DASHBOARD_PORT=3010

# S5.0 Phase B: Celery broker (Redis). Default matches the VPS's localhost Redis; for the
# local-dev compose stack (infra/compose.dev.yml, host port 6390) use:
# SME_CELERY_BROKER_URL=redis://localhost:6390/0

# S5.0 ephemeral GPU worker provisioning. The template id pins the worker Docker image at the
# provider (infra/gpu-worker); the monthly cap (cents, 0=unlimited) refuses provisioning and
# alerts when media-compute spend would exceed it; the per-minute rate accrues lease spend
# (deliberately a conservative over-estimate).
# SME_GPU_PROVIDER=runpod
# SME_GPU_POD_TEMPLATE_ID=
# SME_GPU_IDLE_TEARDOWN_MINUTES=10
# SME_MEDIA_GPU_MONTHLY_CAP_CENTS=0
# SME_GPU_POD_RATE_CENTS_PER_MINUTE=2
# SME_MEDIA_PROVISIONER_INTERVAL_SECONDS=60

# S5.1 short-form video pipeline. ElevenLabs narrates the script (VPS/API step); the render
# rides the `media` queue and the finished MP4 returns via the Celery result backend, capped
# by the max-bytes guard. The re-dispatch bound fails an item `render_failed` instead of
# stranding it in `rendering` when the GPU task keeps dying.
# SME_ELEVENLABS_API_KEY=
# SME_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# SME_VIDEO_RENDER_MAX_BYTES=52428800
# SME_VIDEO_RENDER_TICK_SECONDS=60
# SME_VIDEO_MAX_RENDER_DISPATCHES=3

# S5.2 podcast/audio pipeline. Reuses the ElevenLabs settings above to narrate the episode (a
# VPS/API step). A narration-only episode finishes in-process and never touches the GPU pod; only
# an optional ACE-Step music bed rides the `media` queue, and these render knobs apply to that mix
# (same shape as the video render knobs; ~100 MiB default fits a multi-minute mixed episode).
# SME_PODCAST_RENDER_MAX_BYTES=104857600
# SME_PODCAST_RENDER_TICK_SECONDS=60
# SME_PODCAST_MAX_RENDER_DISPATCHES=3
